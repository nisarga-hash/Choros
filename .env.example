# Choros Backend Configuration
# Copy this file to .env and fill in the values with your own credentials

# ========== EMAIL CONFIGURATION ==========
# Gmail SMTP credentials for OTP email sending
# 
# To set up Gmail:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer" (or your device)
# 3. Generate an app password
# 4. Copy the 16-character password here

SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ========== API CONFIGURATION ==========
# Add any additional API keys or endpoints here
# VITE_API_URL=http://localhost:8000
# VITE_ENABLE_TRANSLATIONS=true
# VITE_ENABLE_SUMMARIZATION=true

# ========== SECURITY NOTES ==========
# NEVER:
# - Commit .env file to version control
# - Share your app password publicly
# - Store passwords in code
# - Push real credentials to GitHub
#
# ALWAYS:
# - Use environment variables for secrets
# - Add .env to .gitignore (already done)
# - Use strong, unique passwords
# - Rotate passwords regularly if compromised
# - Share only .env.example with the team
